# ===============================================================
# Project: wg-easy
# ===============================================================

TIMEZONE=Etc/UTC
ROOT_DIR=/opt/docker/wg-easy

# App: wg-easy
# ===============================================================

WG_IMAGE=ghcr.io/wg-easy/wg-easy:14
WG_CONTAINER=wg-easy-app

# WireGuard Configuration
WG_DOMAIN=wireguard.example.com
WG_PERSISTENT_KEEPALIVE=25
WG_DEFAULT_ADDRESS=10.8.0.x
WG_DEFAULT_DNS=1.1.1.1
WG_ALLOWED_IPS=0.0.0.0/0,::/0
WG_ENABLE_EXPIRES_TIME=false

# Web UI Configuration
WG_UI_LANG=en
WG_UI_HASHED_PASSWORD=
WG_UI_TRAFFIC_STATS=false
WG_UI_CHART_TYPE=0
WG_UI_ENABLE_ONE_TIME_LINKS=false
WG_UI_SESSION_MAX_AGE=0
WG_UI_ENABLE_SORT_CLIENTS=false
WG_UI_ENABLE_PROMETHEUS_METRICS=false
WG_UI_PROMETHEUS_METRICS_PASSWORD=
